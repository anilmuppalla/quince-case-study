{
  "name": "Organic Traffic Spike",
  "description": "Unplanned Search Ranking QPS surge. The scenario shows the normal operating point, the threshold breach that triggers scale-out, and the post-scale state where newly provisioned GPU capacity absorbs the spike without dropping Search traffic.",
  "traffic_windows": [
    {
      "label": "Overnight baseline",
      "start_hour": 0,
      "end_hour": 6,
      "rps_by_model": {
        "search-ranking-v1": 180
      },
      "platform_replicas": {
        "search-ranking-v1": 2
      },
      "event": "normal Search pilot load"
    },
    {
      "label": "Morning ramp",
      "start_hour": 6,
      "end_hour": 8,
      "rps_by_model": {
        "search-ranking-v1": 300
      },
      "platform_replicas": {
        "search-ranking-v1": 3
      },
      "event": "Search max-pod GPU crosses the 50% utilization target"
    },
    {
      "label": "Spike detected before pods ready",
      "start_hour": 8,
      "end_hour": 8.25,
      "rps_by_model": {
        "search-ranking-v1": 420
      },
      "platform_replicas": {
        "search-ranking-v1": 3
      },
      "recommended_replicas": {
        "search-ranking-v1": 5
      },
      "event": "organic spike detected; HPA recommendation emitted"
    },
    {
      "label": "Scale-out serving peak",
      "start_hour": 8.25,
      "end_hour": 12,
      "rps_by_model": {
        "search-ranking-v1": 1400
      },
      "platform_replicas": {
        "search-ranking-v1": 14
      },
      "event": "new GPU pods ready; platform absorbs Search peak"
    },
    {
      "label": "Sustained elevated traffic",
      "start_hour": 12,
      "end_hour": 18,
      "rps_by_model": {
        "search-ranking-v1": 900
      },
      "platform_replicas": {
        "search-ranking-v1": 9
      },
      "event": "right-sized steady peak"
    },
    {
      "label": "Cooldown",
      "start_hour": 18,
      "end_hour": 21,
      "rps_by_model": {
        "search-ranking-v1": 320
      },
      "platform_replicas": {
        "search-ranking-v1": 4
      },
      "event": "autoscaler starts scale-down"
    },
    {
      "label": "Evening baseline",
      "start_hour": 21,
      "end_hour": 24,
      "rps_by_model": {
        "search-ranking-v1": 180
      },
      "platform_replicas": {
        "search-ranking-v1": 2
      },
      "event": "capacity returns to baseline"
    }
  ],
  "key_events": [
    {
      "time": "06:00",
      "decision": "Scale Search 2->3",
      "evidence": "Morning ramp pushes simulated max-pod GPU to 75%, above the strict_realtime 50% target while still below raw pod capacity.",
      "outcome": "Platform adds capacity before requests are rejected; the fixed fleet already has SLA-risk traffic."
    },
    {
      "time": "08:00",
      "decision": "Emit larger HPA recommendation: Search 3->5",
      "evidence": "Organic spike drives simulated max-pod GPU to saturation on the active fleet, far above the 50% target.",
      "outcome": "The system uses the utilization breach as an early warning, not a post-outage signal."
    },
    {
      "time": "08:15",
      "decision": "Serve peak with Search 14 replicas",
      "evidence": "After scale-out, simulated max-pod GPU returns to about 50% on 14 replicas while serving 1.4K RPS.",
      "outcome": "Platform capacity tracks the spike while manual peak provisioning would carry the larger fleet all day."
    },
    {
      "time": "18:00",
      "decision": "Scale down as traffic cools",
      "evidence": "RPS drops below the peak window and max-pod utilization returns near target.",
      "outcome": "Cost falls with demand instead of staying pinned to peak capacity."
    }
  ],
